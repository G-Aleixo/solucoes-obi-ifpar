{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["views/*"],
      "@shared/*": ["shared/components/*"],
      "@hooks/*": ["shared/hooks/*"],
      "@pages/*": ["pages/*"],
      "@provider": ["app/Provider.jsx"],
      "assets/*": ["shared/images/*"]
    }
  },
  "include": ["./"],
  "exclude": ["node_modules"]
}
